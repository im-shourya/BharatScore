# ── Application ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1
APP_NAME=CredSaathi
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=credsaathi
POSTGRES_USER=credsaathi_user
POSTGRES_PASSWORD=strong_password_here
POSTGRES_SSL=false
POSTGRES_MAX_CONNECTIONS=50
POSTGRES_IDLE_TIMEOUT_MS=30000

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_KEY_PREFIX=cs:
REDIS_DEFAULT_TTL=3600

# ── JWT & Keycloak ────────────────────────────────────────
# Leave empty to auto-generate RSA key pair for development
JWT_ACCESS_SECRET=
JWT_ACCESS_PUBLIC=
JWT_ACCESS_EXPIRY=900s
JWT_REFRESH_EXPIRY=7d

# ── OTP ───────────────────────────────────────────────────
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_LOCKOUT_SECONDS=1800

# ── Encryption ────────────────────────────────────────────
# 32-byte hex key (64 hex chars). Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── Rate Limiting ─────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
